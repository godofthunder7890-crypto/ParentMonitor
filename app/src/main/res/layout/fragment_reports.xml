<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#080B14">

    <!-- Header -->
    <LinearLayout android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="#111827"
        android:paddingHorizontal="14dp"
        android:gravity="center_vertical">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="REPORTS &amp; ALERTS"
            android:textColor="#38BDF8" android:textSize="13sp"
            android:fontFamily="sans-serif-medium" android:letterSpacing="0.12"/>
        <TextView android:id="@+id/tvReportStatus"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Ready" android:textColor="#555" android:textSize="11sp"/>
    </LinearLayout>

    <!-- Report button -->
    <Button android:id="@+id/btnGetReport"
        android:layout_width="match_parent" android:layout_height="48dp"
        android:text="📊 Fetch Daily Report"
        android:textSize="13sp" android:textColor="#000"
        android:fontFamily="sans-serif-bold"
        android:backgroundTint="#38BDF8"
        android:stateListAnimator="@null"/>

    <!-- Report content -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_margin="10dp"
        app:cardBackgroundColor="#111827" app:cardCornerRadius="12dp">

        <ScrollView android:layout_width="match_parent"
            android:layout_height="match_parent">
            <TextView android:id="@+id/tvReportContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="14dp"
                android:text="Tap 'Fetch Daily Report' to see today's usage.\n\nAll events, alerts, and reports appear here."
                android:textColor="#555" android:textSize="12sp"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.5"/>
        </ScrollView>
    </androidx.cardview.widget.CardView>

    <!-- Alerts header -->
    <LinearLayout android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="#111827"
        android:paddingHorizontal="14dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="LIVE ALERTS"
            android:textColor="#555" android:textSize="10sp"
            android:letterSpacing="0.12"/>
        <Button android:id="@+id/btnClearAlerts"
            android:layout_width="wrap_content" android:layout_height="28dp"
            android:text="Clear"
            android:textSize="10sp" android:textColor="#888"
            android:backgroundTint="#1F2937"
            android:minWidth="0dp" android:minHeight="0dp"
            android:stateListAnimator="@null"/>
    </LinearLayout>

    <!-- Alerts list -->
    <ListView android:id="@+id/lvAlerts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#111827"
        android:divider="#1F2937" android:dividerHeight="1dp"
        android:padding="4dp"/>

</LinearLayout>
