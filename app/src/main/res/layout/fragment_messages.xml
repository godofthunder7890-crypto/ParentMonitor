<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#060612">

    <!-- Header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:background="#0A0A1E" android:gravity="center_vertical"
        android:paddingStart="20dp" android:paddingEnd="20dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="💬 MESSAGES" android:textSize="15sp"
            android:textColor="#00E5FF" android:fontFamily="monospace" android:letterSpacing="0.1"/>
    </LinearLayout>

    <ProgressBar android:id="@+id/msgProgress"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="center" android:indeterminateTint="#00E5FF"
        android:visibility="gone" android:layout_margin="16dp"/>

    <TextView android:id="@+id/tvMessagesEmpty"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="No messages yet.\nChild can send messages from their device."
        android:textColor="#555577" android:gravity="center"
        android:textSize="13sp" android:lineSpacingMultiplier="1.6"
        android:visibility="gone" android:padding="32dp"/>

    <!-- Messages list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp"
        android:clipToPadding="false"/>

    <!-- Quick replies -->
    <HorizontalScrollView android:layout_width="match_parent" android:layout_height="52dp"
        android:background="#0A0A1E" android:scrollbars="none"
        android:paddingStart="12dp" android:paddingEnd="12dp"
        android:paddingTop="8dp" android:paddingBottom="8dp">
        <LinearLayout android:id="@+id/quickChipsContainer"
            android:layout_width="wrap_content" android:layout_height="match_parent"
            android:orientation="horizontal" android:gravity="center_vertical"/>
    </HorizontalScrollView>

    <!-- Reply input -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="64dp"
        android:background="#0D1033" android:gravity="center_vertical"
        android:paddingStart="12dp" android:paddingEnd="12dp" android:orientation="horizontal">
        <EditText android:id="@+id/etReplyText"
            android:layout_width="0dp" android:layout_height="44dp"
            android:layout_weight="1" android:hint="Reply to child..."
            android:textColor="#FFFFFF" android:textColorHint="#444466"
            android:background="#060612" android:padding="10dp"
            android:inputType="text" android:maxLength="200"
            android:layout_marginEnd="8dp"/>
        <Button android:id="@+id/btnSendReply"
            android:layout_width="72dp" android:layout_height="44dp"
            android:text="SEND" android:textSize="11sp"
            android:textColor="#000000" android:backgroundTint="#00E5FF"/>
    </LinearLayout>
</LinearLayout>
