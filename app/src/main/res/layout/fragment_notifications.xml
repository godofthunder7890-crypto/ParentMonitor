<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#060612">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="#0A0A1E"
        android:padding="12dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <View
            android:id="@+id/notifDot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/circle_green"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="LIVE NOTIFICATIONS"
            android:textColor="#00E5FF"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.1"/>

        <TextView
            android:id="@+id/tvNotifCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#555"
            android:textSize="12sp"
            android:layout_marginEnd="10dp"/>

        <Button
            android:id="@+id/btnClear"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="Clear"
            android:textSize="11sp"
            android:textColor="#888"
            android:backgroundTint="#1A1A2E"
            android:minWidth="0dp" android:minHeight="0dp"
            android:stateListAnimator="@null"/>
    </LinearLayout>

    <!-- Empty state -->
    <TextView
        android:id="@+id/tvNotifEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="32dp"
        android:text="No notifications yet.\nNotifications from child's apps will appear here in real time."
        android:textColor="#333"
        android:textSize="14sp"
        android:gravity="center"
        android:lineSpacingMultiplier="1.5"
        android:visibility="visible"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvNotifications"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="8dp"
        android:clipToPadding="false"/>

</LinearLayout>
