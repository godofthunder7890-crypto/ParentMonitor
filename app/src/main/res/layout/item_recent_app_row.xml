<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical"
    android:background="#0D1117">

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/tvRecentAppName"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="#CCC" android:textSize="14sp"
            android:fontFamily="sans-serif-medium"/>
        <TextView android:id="@+id/tvRecentAppPkg"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="#555" android:textSize="11sp"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <Button android:id="@+id/btnRecentBlock"
        android:layout_width="80dp" android:layout_height="36dp"
        android:text="🚫 Block"
        android:textSize="11sp" android:textColor="#FFF"
        android:backgroundTint="#B71C1C"
        android:stateListAnimator="@null"/>
</LinearLayout>
