<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#070714">

    <!-- TOP STATUS BAR -->
    <LinearLayout
        android:id="@+id/statusBar"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:background="#0D0D20"
        android:paddingStart="16dp"
        android:paddingEnd="12dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:elevation="12dp">

        <!-- App title -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="GuardianEye"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.05"/>

        <!-- Status pill -->
        <LinearLayout
            android:id="@+id/statusPill"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:background="@drawable/pill_offline"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_marginEnd="8dp">
            <View
                android:id="@+id/statusDot"
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:background="@drawable/circle_red"
                android:layout_marginEnd="5dp"/>
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Offline"
                android:textColor="#F44336"
                android:textSize="11sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Battery -->
        <TextView
            android:id="@+id/tvBattery"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textColor="#888"
            android:textSize="12sp"
            android:layout_marginEnd="8dp"/>

        <!-- Ping -->
        <TextView
            android:id="@+id/tvPing"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--ms"
            android:textColor="#888"
            android:textSize="11sp"
            android:layout_marginEnd="8dp"/>

        <!-- Net Toggle -->
        <Button
            android:id="@+id/btnNetToggle"
            android:layout_width="68dp"
            android:layout_height="30dp"
            android:text="NET"
            android:textSize="10sp"
            android:textColor="#000000"
            android:fontFamily="sans-serif-bold"
            android:backgroundTint="#00E5FF"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:stateListAnimator="@null"/>
    </LinearLayout>

    <!-- DIVIDER LINE (cyan glow) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1A00E5FF"/>

    <!-- TAB BAR -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:background="#0D0D20"
        app:tabTextColor="#4D4D6A"
        app:tabSelectedTextColor="#00E5FF"
        app:tabIndicatorColor="#00E5FF"
        app:tabIndicatorHeight="2dp"
        app:tabTextAppearance="@android:style/TextAppearance.Small"
        app:tabMode="scrollable"
        app:tabGravity="fill"
        app:tabPaddingStart="2dp"
        app:tabPaddingEnd="2dp"/>

    <!-- DIVIDER -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#15FFFFFF"/>

    <!-- CONTENT -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>
