<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#050508">

    <!-- Category buttons -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0D0D1A"
        android:paddingStart="8dp" android:paddingEnd="8dp"
        android:paddingTop="8dp" android:paddingBottom="8dp">

        <LinearLayout android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:orientation="horizontal">

            <Button android:id="@+id/btnDataGallery"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="🖼 Gallery" android:textSize="12sp" android:textColor="#000"
                android:backgroundTint="#00D4FF" android:layout_marginEnd="6dp"/>

            <Button android:id="@+id/btnDataCalls"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="📞 Calls" android:textSize="12sp" android:textColor="#FFF"
                android:backgroundTint="#1A1A2E" android:layout_marginEnd="6dp"/>

            <Button android:id="@+id/btnDataSms"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="💬 SMS" android:textSize="12sp" android:textColor="#FFF"
                android:backgroundTint="#1A1A2E" android:layout_marginEnd="6dp"/>

            <Button android:id="@+id/btnDataApps"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="📱 Apps" android:textSize="12sp" android:textColor="#FFF"
                android:backgroundTint="#1A1A2E"/>

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Status / fetch button -->
    <LinearLayout android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="10dp"
        android:gravity="center_vertical"
        android:background="#080812">

        <TextView android:id="@+id/tvDataStatus"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Select a category and tap Fetch"
            android:textColor="#555" android:textSize="12sp"/>

        <Button android:id="@+id/btnDataFetch"
            android:layout_width="wrap_content" android:layout_height="34dp"
            android:text="Fetch" android:textSize="12sp"
            android:backgroundTint="#00D4FF" android:textColor="#000"
            android:paddingStart="16dp" android:paddingEnd="16dp"/>

    </LinearLayout>

    <!-- Gallery grid (visible when gallery selected) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvDataGallery"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="visible"
        android:padding="4dp"/>

    <!-- List (for calls/SMS/apps) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvDataList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone"/>

</LinearLayout>
