<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:gravity="end" android:orientation="vertical" android:paddingBottom="8dp">
    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:orientation="vertical" android:background="#003344"
        android:paddingStart="14dp" android:paddingEnd="14dp"
        android:paddingTop="10dp" android:paddingBottom="10dp"
        android:layout_marginStart="64dp">
        <TextView android:id="@+id/tvMsgText"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#00E5FF" android:textSize="14sp" android:lineSpacingMultiplier="1.4"/>
        <TextView android:id="@+id/tvMsgSuggested"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#00E5FF" android:textSize="11sp"
            android:layout_marginTop="4dp" android:visibility="gone"/>
        <TextView android:id="@+id/tvMsgTime"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#555577" android:textSize="10sp" android:layout_marginTop="4dp"/>
    </LinearLayout>
</LinearLayout>
