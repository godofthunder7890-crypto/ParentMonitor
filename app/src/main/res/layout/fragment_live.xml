<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#070714"
    android:orientation="vertical">

    <!-- TAB SELECTOR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="#0D0D20"
        android:orientation="horizontal"
        android:padding="6dp">

        <Button
            android:id="@+id/btnTabScreen"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="SCREEN"
            android:textSize="11sp"
            android:textColor="#000"
            android:fontFamily="sans-serif-bold"
            android:backgroundTint="#00E5FF"
            android:stateListAnimator="@null"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btnTabCamera"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="CAMERA"
            android:textSize="11sp"
            android:textColor="#AAAAAA"
            android:fontFamily="sans-serif-bold"
            android:backgroundTint="#1A1A2E"
            android:stateListAnimator="@null"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btnTabMic"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="MIC"
            android:textSize="11sp"
            android:textColor="#AAAAAA"
            android:fontFamily="sans-serif-bold"
            android:backgroundTint="#1A1A2E"
            android:stateListAnimator="@null"/>
    </LinearLayout>

    <!-- SCREEN PANEL -->
    <LinearLayout
        android:id="@+id/panelScreen"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="#070714">

        <!-- Frame display — fills most of the screen -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#000000">
            <ImageView
                android:id="@+id/imgScreen"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:adjustViewBounds="true"/>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:background="#80000000"
                android:padding="6dp"
                android:orientation="horizontal">
                <View
                    android:id="@+id/dotScreen"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/circle_red"
                    android:layout_marginEnd="4dp"
                    android:layout_gravity="center_vertical"/>
                <TextView
                    android:id="@+id/tvScreenInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Stopped"
                    android:textColor="#AAAAAA"
                    android:textSize="10sp"/>
                <TextView
                    android:id="@+id/tvScreenFps"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#00E5FF"
                    android:textSize="10sp"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>
        </FrameLayout>

        <!-- Controls bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="#0D0D20"
            android:orientation="horizontal"
            android:padding="8dp"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnScreenFaster"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="+"
                android:textSize="16sp"
                android:textColor="#000"
                android:backgroundTint="#00E5FF"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:stateListAnimator="@null"
                android:padding="0dp"/>
            <TextView
                android:id="@+id/tvScreenInterval"
                android:layout_width="50dp"
                android:layout_height="wrap_content"
                android:text="1s"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:gravity="center"
                android:textStyle="bold"/>
            <Button
                android:id="@+id/btnScreenSlower"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="-"
                android:textSize="16sp"
                android:textColor="#000"
                android:backgroundTint="#444455"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:stateListAnimator="@null"
                android:padding="0dp"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnToggleScreen"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="START SCREEN"
                android:textSize="11sp"
                android:textColor="#000"
                android:fontFamily="sans-serif-bold"
                android:backgroundTint="#00E5FF"
                android:stateListAnimator="@null"/>
        </LinearLayout>
    </LinearLayout>

    <!-- CAMERA PANEL -->
    <LinearLayout
        android:id="@+id/panelCamera"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:visibility="gone">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#000000">
            <ImageView
                android:id="@+id/imgCamera"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"/>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:background="#80000000"
                android:padding="6dp"
                android:orientation="horizontal">
                <View
                    android:id="@+id/dotCamera"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/circle_red"
                    android:layout_marginEnd="4dp"
                    android:layout_gravity="center_vertical"/>
                <TextView
                    android:id="@+id/tvCameraInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Stopped"
                    android:textColor="#AAAAAA"
                    android:textSize="10sp"/>
                <TextView
                    android:id="@+id/tvCameraFps"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#AA00FF"
                    android:textSize="10sp"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="#0D0D20"
            android:padding="8dp">
            <Button
                android:id="@+id/btnToggleCamera"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="START CAMERA"
                android:textSize="11sp"
                android:textColor="#000"
                android:fontFamily="sans-serif-bold"
                android:backgroundTint="#AA00FF"
                android:stateListAnimator="@null"/>
        </LinearLayout>
    </LinearLayout>

    <!-- MIC PANEL -->
    <LinearLayout
        android:id="@+id/panelMic"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        android:visibility="gone">

        <View
            android:id="@+id/dotMic"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/circle_red"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/tvMicStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mic Off"
            android:textColor="#555566"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btnToggleMic"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="START LISTENING"
            android:textSize="13sp"
            android:textColor="#000"
            android:fontFamily="sans-serif-bold"
            android:backgroundTint="#00C853"
            android:stateListAnimator="@null"/>
    </LinearLayout>

</LinearLayout>
