<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080B14"
    android:orientation="vertical">

    <!-- TAB SELECTOR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="#0D1117"
        android:orientation="horizontal"
        android:padding="6dp">

        <Button
            android:id="@+id/btnTabScreen"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="SCREEN"
            android:textSize="11sp"
            android:textColor="#000"
            android:fontFamily="sans-serif-bold"
            android:backgroundTint="#38BDF8"
            android:stateListAnimator="@null"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btnTabCamera"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="CAMERA"
            android:textSize="11sp"
            android:textColor="#94A3B8"
            android:fontFamily="sans-serif-bold"
            android:backgroundTint="#1F2937"
            android:stateListAnimator="@null"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btnTabMic"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="MIC"
            android:textSize="11sp"
            android:textColor="#94A3B8"
            android:fontFamily="sans-serif-bold"
            android:backgroundTint="#1F2937"
            android:stateListAnimator="@null"/>
    </LinearLayout>

    <!-- SCREEN PANEL -->
    <LinearLayout
        android:id="@+id/panelScreen"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="#080B14">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#000000">
            <ImageView
                android:id="@+id/imgScreen"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:adjustViewBounds="true"/>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:background="#80000000"
                android:padding="6dp"
                android:orientation="horizontal">
                <View
                    android:id="@+id/dotScreen"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/circle_red"
                    android:layout_marginEnd="4dp"
                    android:layout_gravity="center_vertical"/>
                <TextView
                    android:id="@+id/tvScreenInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Stopped"
                    android:textColor="#94A3B8"
                    android:textSize="10sp"/>
                <TextView
                    android:id="@+id/tvScreenFps"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#38BDF8"
                    android:textSize="10sp"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>
        </FrameLayout>

        <!-- Screen controls bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="#0D1117"
            android:orientation="horizontal"
            android:padding="8dp"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnScreenFaster"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="+"
                android:textSize="16sp"
                android:textColor="#000"
                android:backgroundTint="#38BDF8"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:stateListAnimator="@null"
                android:padding="0dp"/>
            <TextView
                android:id="@+id/tvScreenInterval"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:text="1fps"
                android:textColor="#F1F5F9"
                android:textSize="11sp"
                android:gravity="center"
                android:textStyle="bold"/>
            <Button
                android:id="@+id/btnScreenSlower"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="-"
                android:textSize="16sp"
                android:textColor="#000"
                android:backgroundTint="#444455"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:stateListAnimator="@null"
                android:padding="0dp"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnToggleScreen"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="START SCREEN"
                android:textSize="11sp"
                android:textColor="#000"
                android:fontFamily="sans-serif-bold"
                android:backgroundTint="#38BDF8"
                android:stateListAnimator="@null"/>
        </LinearLayout>
    </LinearLayout>

    <!-- CAMERA PANEL -->
    <LinearLayout
        android:id="@+id/panelCamera"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:visibility="gone">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#000000">
            <ImageView
                android:id="@+id/imgCamera"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"/>
            <org.webrtc.SurfaceViewRenderer
                android:id="@+id/webrtcRenderer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"/>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:background="#80000000"
                android:padding="6dp"
                android:orientation="horizontal">
                <View
                    android:id="@+id/dotCamera"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/circle_red"
                    android:layout_marginEnd="4dp"
                    android:layout_gravity="center_vertical"/>
                <TextView
                    android:id="@+id/tvCameraInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Stopped"
                    android:textColor="#94A3B8"
                    android:textSize="10sp"/>
                <TextView
                    android:id="@+id/tvCameraFps"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#A78BFA"
                    android:textSize="10sp"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>
        </FrameLayout>

        <!-- Camera controls: fps +/- | FLIP | START/STOP -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="#0D1117"
            android:orientation="horizontal"
            android:padding="8dp"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnCameraFaster"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="+"
                android:textSize="16sp"
                android:textColor="#000"
                android:backgroundTint="#A78BFA"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:stateListAnimator="@null"
                android:padding="0dp"/>
            <TextView
                android:id="@+id/tvCameraInterval"
                android:layout_width="52dp"
                android:layout_height="wrap_content"
                android:text="30fps"
                android:textColor="#F1F5F9"
                android:textSize="11sp"
                android:gravity="center"
                android:textStyle="bold"/>
            <Button
                android:id="@+id/btnCameraSlower"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="-"
                android:textSize="16sp"
                android:textColor="#000"
                android:backgroundTint="#444455"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:stateListAnimator="@null"
                android:padding="0dp"/>

            <Button
                android:id="@+id/btnSwitchCamera"
                android:layout_width="46dp"
                android:layout_height="36dp"
                android:text="FLIP"
                android:textSize="9sp"
                android:textColor="#A78BFA"
                android:backgroundTint="#1A0030"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:stateListAnimator="@null"
                android:padding="0dp"
                android:layout_marginStart="4dp"/>

            <Button
                android:id="@+id/btnToggleCamera"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="START CAMERA"
                android:textSize="10sp"
                android:textColor="#000"
                android:fontFamily="sans-serif-bold"
                android:backgroundTint="#A78BFA"
                android:stateListAnimator="@null"
                android:layout_marginStart="4dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- MIC PANEL -->
    <LinearLayout
        android:id="@+id/panelMic"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        android:visibility="gone">

        <View
            android:id="@+id/dotMic"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/circle_red"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/tvMicStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mic Off"
            android:textColor="#64748B"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btnToggleMic"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="START LISTENING"
            android:textSize="13sp"
            android:textColor="#000"
            android:fontFamily="sans-serif-bold"
            android:backgroundTint="#10FF80"
            android:stateListAnimator="@null"/>
    </LinearLayout>

</LinearLayout>
