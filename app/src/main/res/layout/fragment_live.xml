<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#060612">

    <!-- Tab selector -->
    <LinearLayout
        android:id="@+id/liveTabs"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="#0A0A1E"
        android:padding="8dp">

        <Button android:id="@+id/btnTabScreen"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:layout_marginEnd="4dp"
            android:text="🖥 Screen"
            android:textSize="12sp" android:textColor="#000"
            android:backgroundTint="#00E5FF"
            android:stateListAnimator="@null"/>

        <Button android:id="@+id/btnTabCamera"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:layout_marginEnd="4dp"
            android:text="📷 Camera"
            android:textSize="12sp" android:textColor="#AAA"
            android:backgroundTint="#1A1A2E"
            android:stateListAnimator="@null"/>

        <Button android:id="@+id/btnTabMic"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="🎤 Mic"
            android:textSize="12sp" android:textColor="#AAA"
            android:backgroundTint="#1A1A2E"
            android:stateListAnimator="@null"/>
    </LinearLayout>

    <!-- ── SCREEN PANEL ───────────────────────────────── -->
    <LinearLayout
        android:id="@+id/panelScreen"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:visibility="visible">

        <!-- Stream view -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#000">

            <ImageView android:id="@+id/imgScreen"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:background="#000"/>

            <!-- Overlay info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:background="#88000000"
                android:padding="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View android:id="@+id/dotScreen"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/circle_red"
                    android:layout_marginEnd="8dp"/>

                <TextView android:id="@+id/tvScreenInfo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Stopped"
                    android:textColor="#AAA"
                    android:textSize="11sp"/>

                <TextView android:id="@+id/tvScreenFps"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 fps"
                    android:textColor="#00E5FF"
                    android:textSize="11sp"/>
            </LinearLayout>
        </FrameLayout>

        <!-- Control row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#0A0A1E"
            android:padding="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button android:id="@+id/btnToggleScreen"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="▶ START SCREEN"
                android:textSize="13sp" android:textColor="#000"
                android:fontFamily="sans-serif-bold"
                android:backgroundTint="#00E5FF"
                android:stateListAnimator="@null"/>

            <TextView android:id="@+id/tvScreenInterval"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1s"
                android:textColor="#555"
                android:textSize="12sp"
                android:minWidth="30dp"
                android:gravity="center"/>

            <Button android:id="@+id/btnScreenFaster"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="+"
                android:textSize="16sp" android:textColor="#00E5FF"
                android:backgroundTint="#0A1A2F"
                android:minWidth="0dp" android:minHeight="0dp"
                android:stateListAnimator="@null"/>

            <Button android:id="@+id/btnScreenSlower"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="-"
                android:textSize="16sp" android:textColor="#00E5FF"
                android:backgroundTint="#0A1A2F"
                android:layout_marginStart="4dp"
                android:minWidth="0dp" android:minHeight="0dp"
                android:stateListAnimator="@null"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ── CAMERA PANEL ───────────────────────────────── -->
    <LinearLayout
        android:id="@+id/panelCamera"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:visibility="gone">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#000">

            <ImageView android:id="@+id/imgCamera"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:background="#000"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:background="#88000000"
                android:padding="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View android:id="@+id/dotCamera"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/circle_red"
                    android:layout_marginEnd="8dp"/>

                <TextView android:id="@+id/tvCameraInfo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Stopped"
                    android:textColor="#AAA"
                    android:textSize="11sp"/>

                <TextView android:id="@+id/tvCameraFps"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 fps"
                    android:textColor="#CE93D8"
                    android:textSize="11sp"/>
            </LinearLayout>
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#0A0A1E"
            android:padding="8dp"
            android:orientation="horizontal">

            <Button android:id="@+id/btnToggleCamera"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="▶ START CAMERA"
                android:textSize="13sp" android:textColor="#FFF"
                android:fontFamily="sans-serif-bold"
                android:backgroundTint="#6A1B9A"
                android:stateListAnimator="@null"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ── MIC PANEL ─────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/panelMic"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <View android:id="@+id/dotMic"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/circle_red"
            android:layout_marginBottom="24dp"/>

        <TextView android:id="@+id/tvMicStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mic Off"
            android:textColor="#555"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="32dp"/>

        <Button android:id="@+id/btnToggleMic"
            android:layout_width="200dp"
            android:layout_height="52dp"
            android:text="▶ START LISTENING"
            android:textSize="13sp" android:textColor="#000"
            android:fontFamily="sans-serif-bold"
            android:backgroundTint="#00C853"
            android:stateListAnimator="@null"/>
    </LinearLayout>

</LinearLayout>
