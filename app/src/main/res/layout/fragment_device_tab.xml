<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBgLight">

    <!-- Purple gradient header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_purple"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:paddingTop="20dp"
        android:paddingBottom="20dp">

        <!-- Avatar circle -->
        <FrameLayout
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginEnd="12dp">
            <View
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/circle_white_shine"/>
            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_my_calendar"
                android:tint="#7C4DFF"/>
        </FrameLayout>

        <!-- Device name + status + battery -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvDeviceName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Unknown Device"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <!-- Status dot -->
                <View
                    android:id="@+id/devStatusDot"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/circle_orange"
                    android:layout_marginEnd="6dp"/>

                <TextView
                    android:id="@+id/tvDeviceStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Offline"
                    android:textColor="#E0E0E0"
                    android:textSize="13sp"
                    android:layout_marginEnd="14dp"/>

                <!-- Battery -->
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/ic_lock_idle_charging"
                    android:tint="#4CAF50"
                    android:layout_marginEnd="4dp"/>
                <TextView
                    android:id="@+id/tvDeviceBattery"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--%"
                    android:textColor="#E0E0E0"
                    android:textSize="13sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Dropdown arrow -->
        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@android:drawable/arrow_down_float"
            android:tint="#FFFFFF"
            android:layout_marginEnd="8dp"/>

        <!-- Vertical divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="28dp"
            android:background="#FFFFFF"
            android:alpha="0.4"
            android:layout_marginEnd="8dp"/>

        <!-- Plus / Add device -->
        <TextView
            android:id="@+id/btnAddDevice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" + "
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- Permission alert banner (dismissible) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardPermBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:visibility="gone"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="The device's permissions are abnormal ›"
                            android:textColor="#212121"
                            android:textSize="13sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Tap to check permissions"
                            android:textColor="#9E9E9E"
                            android:textSize="12sp"/>
                    </LinearLayout>
                    <TextView
                        android:id="@+id/btnDismissBanner"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✕"
                        android:textColor="#9E9E9E"
                        android:textSize="18sp"
                        android:padding="4dp"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ━━━━━━━━━━━━━ LIVE MONITORING ━━━━━━━━━━━━━ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Section title -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Live Monitoring"
                            android:textColor="#212121"
                            android:textSize="15sp"
                            android:textStyle="bold"/>
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_menu_preferences"
                            android:tint="#9E9E9E"/>
                    </LinearLayout>

                    <!-- 3 monitoring buttons -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Remote Camera -->
                        <LinearLayout
                            android:id="@+id/btnRemoteCamera"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="6dp"
                            android:clickable="true"
                            android:focusable="true">
                            <FrameLayout
                                android:layout_width="56dp"
                                android:layout_height="56dp">
                                <View
                                    android:layout_width="56dp"
                                    android:layout_height="56dp"
                                    android:background="@drawable/circle_purple"/>
                                <ImageView
                                    android:layout_width="28dp"
                                    android:layout_height="28dp"
                                    android:layout_gravity="center"
                                    android:src="@android:drawable/ic_menu_camera"
                                    android:tint="#7C4DFF"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="bottom|start"
                                    android:text=" PRO "
                                    android:textSize="7sp"
                                    android:textColor="#000000"
                                    android:background="@drawable/bg_pro_badge"
                                    android:padding="1dp"/>
                            </FrameLayout>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="Remote\nCamera"
                                android:textSize="11sp"
                                android:textColor="#424242"
                                android:gravity="center"/>
                        </LinearLayout>

                        <!-- Screen Mirroring -->
                        <LinearLayout
                            android:id="@+id/btnScreenMirror"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="6dp"
                            android:clickable="true"
                            android:focusable="true">
                            <FrameLayout
                                android:layout_width="56dp"
                                android:layout_height="56dp">
                                <View
                                    android:layout_width="56dp"
                                    android:layout_height="56dp"
                                    android:background="@drawable/circle_purple"/>
                                <ImageView
                                    android:layout_width="28dp"
                                    android:layout_height="28dp"
                                    android:layout_gravity="center"
                                    android:src="@android:drawable/ic_menu_send"
                                    android:tint="#7C4DFF"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="bottom|start"
                                    android:text=" PRO "
                                    android:textSize="7sp"
                                    android:textColor="#000000"
                                    android:background="@drawable/bg_pro_badge"
                                    android:padding="1dp"/>
                            </FrameLayout>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="Screen\nMirroring"
                                android:textSize="11sp"
                                android:textColor="#424242"
                                android:gravity="center"/>
                        </LinearLayout>

                        <!-- One-Way Audio -->
                        <LinearLayout
                            android:id="@+id/btnOneWayAudio"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="6dp"
                            android:clickable="true"
                            android:focusable="true">
                            <FrameLayout
                                android:layout_width="56dp"
                                android:layout_height="56dp">
                                <View
                                    android:layout_width="56dp"
                                    android:layout_height="56dp"
                                    android:background="@drawable/circle_purple"/>
                                <ImageView
                                    android:layout_width="28dp"
                                    android:layout_height="28dp"
                                    android:layout_gravity="center"
                                    android:src="@android:drawable/ic_btn_speak_now"
                                    android:tint="#7C4DFF"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="bottom|start"
                                    android:text=" PRO "
                                    android:textSize="7sp"
                                    android:textColor="#000000"
                                    android:background="@drawable/bg_pro_badge"
                                    android:padding="1dp"/>
                            </FrameLayout>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="One-Way\nAudio"
                                android:textSize="11sp"
                                android:textColor="#424242"
                                android:gravity="center"/>
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ━━━━━━━━━━━━━ BLOCK ALL APPS ━━━━━━━━━━━━━ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">
                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@android:drawable/ic_lock_lock"
                        android:tint="#7C4DFF"
                        android:background="@drawable/circle_purple"
                        android:padding="8dp"
                        android:layout_marginEnd="14dp"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Block All Apps"
                            android:textColor="#212121"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="All apps except Allowed Apps will be blocked"
                            android:textColor="#9E9E9E"
                            android:textSize="11sp"/>
                    </LinearLayout>
                    <Switch
                        android:id="@+id/switchBlockApps"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:thumbTint="#7C4DFF"
                        android:trackTint="#E0E0E0"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ━━━━━━━━━━━━━ LIVE LOCATION ━━━━━━━━━━━━━ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Live Location"
                            android:textColor="#212121"
                            android:textSize="15sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="#7C4DFF"
                            android:textSize="22sp"/>
                    </LinearLayout>
                    <TextView
                        android:id="@+id/tvLocationAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Fetching location..."
                        android:textColor="#424242"
                        android:textSize="13sp"/>
                    <TextView
                        android:id="@+id/tvLocationUpdate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text=""
                        android:textColor="#9E9E9E"
                        android:textSize="11sp"/>
                    <TextView
                        android:id="@+id/btnOpenMap"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_header_purple"
                        android:gravity="center"
                        android:text="Open Full Map"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ━━━━━━━━━━━━━ SNAPSHOT & RECORDING ━━━━━━━━━━━━━ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="Snapshot &amp; Recording"
                        android:textColor="#212121"
                        android:textSize="15sp"
                        android:textStyle="bold"/>

                    <!-- Row 1 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <LinearLayout android:id="@+id/btnCamRecord"
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical"
                            android:gravity="center" android:padding="6dp"
                            android:clickable="true" android:focusable="true">
                            <FrameLayout android:layout_width="52dp" android:layout_height="52dp">
                                <View android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/circle_purple"/>
                                <ImageView android:layout_width="26dp" android:layout_height="26dp" android:layout_gravity="center" android:src="@android:drawable/ic_media_play" android:tint="#7C4DFF"/>
                            </FrameLayout>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:text="Camera\nRecording" android:textSize="11sp" android:textColor="#424242" android:gravity="center"/>
                        </LinearLayout>

                        <LinearLayout android:id="@+id/btnScreenRecord"
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical"
                            android:gravity="center" android:padding="6dp"
                            android:clickable="true" android:focusable="true">
                            <FrameLayout android:layout_width="52dp" android:layout_height="52dp">
                                <View android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/circle_purple"/>
                                <ImageView android:layout_width="26dp" android:layout_height="26dp" android:layout_gravity="center" android:src="@android:drawable/ic_menu_send" android:tint="#7C4DFF"/>
                            </FrameLayout>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:text="Screen\nRecording" android:textSize="11sp" android:textColor="#424242" android:gravity="center"/>
                        </LinearLayout>

                        <LinearLayout android:id="@+id/btnAmbientRecord"
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical"
                            android:gravity="center" android:padding="6dp"
                            android:clickable="true" android:focusable="true">
                            <FrameLayout android:layout_width="52dp" android:layout_height="52dp">
                                <View android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/circle_purple"/>
                                <ImageView android:layout_width="26dp" android:layout_height="26dp" android:layout_gravity="center" android:src="@android:drawable/ic_btn_speak_now" android:tint="#7C4DFF"/>
                            </FrameLayout>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:text="Ambient\nRecording" android:textSize="11sp" android:textColor="#424242" android:gravity="center"/>
                        </LinearLayout>

                    </LinearLayout>

                    <!-- Row 2 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout android:id="@+id/btnCamSnapshot"
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical"
                            android:gravity="center" android:padding="6dp"
                            android:clickable="true" android:focusable="true">
                            <FrameLayout android:layout_width="52dp" android:layout_height="52dp">
                                <View android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/circle_purple"/>
                                <ImageView android:layout_width="26dp" android:layout_height="26dp" android:layout_gravity="center" android:src="@android:drawable/ic_menu_camera" android:tint="#7C4DFF"/>
                            </FrameLayout>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:text="Camera\nSnapshot" android:textSize="11sp" android:textColor="#424242" android:gravity="center"/>
                        </LinearLayout>

                        <LinearLayout android:id="@+id/btnScreenSnapshot"
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical"
                            android:gravity="center" android:padding="6dp"
                            android:clickable="true" android:focusable="true">
                            <FrameLayout android:layout_width="52dp" android:layout_height="52dp">
                                <View android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/circle_purple"/>
                                <ImageView android:layout_width="26dp" android:layout_height="26dp" android:layout_gravity="center" android:src="@android:drawable/ic_menu_crop" android:tint="#7C4DFF"/>
                            </FrameLayout>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:text="Screen\nSnapshot" android:textSize="11sp" android:textColor="#424242" android:gravity="center"/>
                        </LinearLayout>

                        <!-- Empty placeholder -->
                        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ━━━━━━━━━━━━━ DEVICE ACTIVITY ━━━━━━━━━━━━━ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="Device Activity"
                        android:textColor="#212121"
                        android:textSize="15sp"
                        android:textStyle="bold"/>

                    <!-- Row 1 -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">

                        <LinearLayout android:id="@+id/btnScreenTime"
                            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:orientation="vertical" android:gravity="center" android:padding="6dp" android:clickable="true" android:focusable="true">
                            <FrameLayout android:layout_width="52dp" android:layout_height="52dp">
                                <View android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/circle_purple"/>
                                <ImageView android:layout_width="26dp" android:layout_height="26dp" android:layout_gravity="center" android:src="@android:drawable/ic_menu_recent_history" android:tint="#7C4DFF"/>
                            </FrameLayout>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:text="Screen Time\nLimits" android:textSize="11sp" android:textColor="#424242" android:gravity="center"/>
                        </LinearLayout>

                        <LinearLayout android:id="@+id/btnAppTime"
                            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:orientation="vertical" android:gravity="center" android:padding="6dp" android:clickable="true" android:focusable="true">
                            <FrameLayout android:layout_width="52dp" android:layout_height="52dp">
                                <View android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/circle_purple"/>
                                <ImageView android:layout_width="26dp" android:layout_height="26dp" android:layout_gravity="center" android:src="@android:drawable/ic_menu_agenda" android:tint="#7C4DFF"/>
                            </FrameLayout>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:text="App Time\nLimits" android:textSize="11sp" android:textColor="#424242" android:gravity="center"/>
                        </LinearLayout>

                        <LinearLayout android:id="@+id/btnAppRules"
                            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:orientation="vertical" android:gravity="center" android:padding="6dp" android:clickable="true" android:focusable="true">
                            <FrameLayout android:layout_width="52dp" android:layout_height="52dp">
                                <View android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/circle_purple"/>
                                <ImageView android:layout_width="26dp" android:layout_height="26dp" android:layout_gravity="center" android:src="@android:drawable/ic_lock_lock" android:tint="#7C4DFF"/>
                            </FrameLayout>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:text="App\nRules" android:textSize="11sp" android:textColor="#424242" android:gravity="center"/>
                        </LinearLayout>

                    </LinearLayout>

                    <!-- Row 2 -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">

                        <LinearLayout android:id="@+id/btnUsageLogs"
                            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:orientation="vertical" android:gravity="center" android:padding="6dp" android:clickable="true" android:focusable="true">
                            <FrameLayout android:layout_width="52dp" android:layout_height="52dp">
                                <View android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/circle_purple"/>
                                <ImageView android:layout_width="26dp" android:layout_height="26dp" android:layout_gravity="center" android:src="@android:drawable/ic_menu_info_details" android:tint="#7C4DFF"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="bottom|start" android:text=" PRO " android:textSize="7sp" android:textColor="#000000" android:background="@drawable/bg_pro_badge" android:padding="1dp"/>
                            </FrameLayout>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:text="Usage\nLogs" android:textSize="11sp" android:textColor="#424242" android:gravity="center"/>
                        </LinearLayout>

                        <LinearLayout android:id="@+id/btnLivePainting"
                            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:orientation="vertical" android:gravity="center" android:padding="6dp" android:clickable="true" android:focusable="true">
                            <FrameLayout android:layout_width="52dp" android:layout_height="52dp">
                                <View android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/circle_purple"/>
                                <ImageView android:layout_width="26dp" android:layout_height="26dp" android:layout_gravity="center" android:src="@android:drawable/ic_menu_edit" android:tint="#7C4DFF"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="top|start" android:text=" Beta " android:textSize="7sp" android:textColor="#FFFFFF" android:background="#4CAF50" android:padding="1dp"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="bottom|start" android:text=" PRO " android:textSize="7sp" android:textColor="#000000" android:background="@drawable/bg_pro_badge" android:padding="1dp"/>
                            </FrameLayout>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:text="Live\nPainting" android:textSize="11sp" android:textColor="#424242" android:gravity="center"/>
                        </LinearLayout>

                        <LinearLayout android:id="@+id/btnCheckPerms"
                            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:orientation="vertical" android:gravity="center" android:padding="6dp" android:clickable="true" android:focusable="true">
                            <FrameLayout android:layout_width="52dp" android:layout_height="52dp">
                                <View android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/circle_purple"/>
                                <ImageView android:layout_width="26dp" android:layout_height="26dp" android:layout_gravity="center" android:src="@android:drawable/ic_menu_preferences" android:tint="#7C4DFF"/>
                            </FrameLayout>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:text="Check\nPermissions" android:textSize="11sp" android:textColor="#424242" android:gravity="center"/>
                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ━━━━━━━━━━━━━ USAGE SAFETY ━━━━━━━━━━━━━ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="Usage Safety"
                        android:textColor="#212121"
                        android:textSize="15sp"
                        android:textStyle="bold"/>

                    <!-- Row 1 -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">

                        <LinearLayout android:id="@+id/btnSocialDetect"
                            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:orientation="vertical" android:gravity="center" android:padding="6dp" android:clickable="true" android:focusable="true">
                            <FrameLayout android:layout_width="52dp" android:layout_height="52dp">
                                <View android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/circle_purple"/>
                                <ImageView android:layout_width="26dp" android:layout_height="26dp" android:layout_gravity="center" android:src="@android:drawable/ic_dialog_dialer" android:tint="#7C4DFF"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="bottom|start" android:text=" PRO " android:textSize="7sp" android:textColor="#000000" android:background="@drawable/bg_pro_badge" android:padding="1dp"/>
                            </FrameLayout>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:text="Social App\nDetection" android:textSize="11sp" android:textColor="#424242" android:gravity="center"/>
                        </LinearLayout>

                        <LinearLayout android:id="@+id/btnCallSms"
                            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:orientation="vertical" android:gravity="center" android:padding="6dp" android:clickable="true" android:focusable="true">
                            <FrameLayout android:layout_width="52dp" android:layout_height="52dp">
                                <View android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/circle_purple"/>
                                <ImageView android:layout_width="26dp" android:layout_height="26dp" android:layout_gravity="center" android:src="@android:drawable/ic_call_answer" android:tint="#7C4DFF"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="bottom|start" android:text=" PRO " android:textSize="7sp" android:textColor="#000000" android:background="@drawable/bg_pro_badge" android:padding="1dp"/>
                            </FrameLayout>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:text="Call &amp; SMS\nSafety" android:textSize="11sp" android:textColor="#424242" android:gravity="center"/>
                        </LinearLayout>

                        <LinearLayout android:id="@+id/btnAlbums"
                            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:orientation="vertical" android:gravity="center" android:padding="6dp" android:clickable="true" android:focusable="true">
                            <FrameLayout android:layout_width="52dp" android:layout_height="52dp">
                                <View android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/circle_purple"/>
                                <ImageView android:layout_width="26dp" android:layout_height="26dp" android:layout_gravity="center" android:src="@android:drawable/ic_menu_gallery" android:tint="#7C4DFF"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="bottom|start" android:text=" PRO " android:textSize="7sp" android:textColor="#000000" android:background="@drawable/bg_pro_badge" android:padding="1dp"/>
                            </FrameLayout>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:text="Albums\nSafety" android:textSize="11sp" android:textColor="#424242" android:gravity="center"/>
                        </LinearLayout>

                    </LinearLayout>

                    <!-- Row 2 -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">

                        <LinearLayout android:id="@+id/btnBrowserSafety"
                            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:orientation="vertical" android:gravity="center" android:padding="6dp" android:clickable="true" android:focusable="true">
                            <FrameLayout android:layout_width="52dp" android:layout_height="52dp">
                                <View android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/circle_purple"/>
                                <ImageView android:layout_width="26dp" android:layout_height="26dp" android:layout_gravity="center" android:src="@android:drawable/ic_menu_search" android:tint="#7C4DFF"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="bottom|start" android:text=" PRO " android:textSize="7sp" android:textColor="#000000" android:background="@drawable/bg_pro_badge" android:padding="1dp"/>
                            </FrameLayout>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:text="Browser\nSafety" android:textSize="11sp" android:textColor="#424242" android:gravity="center"/>
                        </LinearLayout>

                        <!-- Empty slots -->
                        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>
                        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ━━━━━━━━━━━━━ HOW TO OPEN HIDDEN CHILD APP ━━━━━━━━━━━━━ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardHowToOpen"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp"
                    android:clickable="true"
