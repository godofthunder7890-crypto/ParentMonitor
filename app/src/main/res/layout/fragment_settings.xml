<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#070714">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- ═══ SERVER CONFIG ═══ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#0D0D21"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="10dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SERVER CONFIG"
                    android:textColor="#333355"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="12dp"/>
                <EditText
                    android:id="@+id/etServerUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="wss://your-server.replit.app/api/ws"
                    android:inputType="textUri"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#333355"
                    android:background="#0A0A1A"
                    android:padding="12dp"
                    android:fontFamily="monospace"
                    android:textSize="12sp"
                    android:layout_marginBottom="8dp"/>
                <EditText
                    android:id="@+id/etPairCode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="6-digit pair code"
                    android:inputType="number"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#333355"
                    android:background="#0A0A1A"
                    android:padding="12dp"
                    android:fontFamily="monospace"
                    android:textSize="16sp"
                    android:layout_marginBottom="10dp"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <Button
                        android:id="@+id/btnSaveUrl"
                        android:layout_width="0dp"
                        android:layout_height="46dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:text="SAVE"
                        android:fontFamily="monospace"
                        android:backgroundTint="#00E5FF"
                        android:textColor="#000000"
                        style="@style/Widget.MaterialComponents.Button"/>
                    <Button
                        android:id="@+id/btnScanQr"
                        android:layout_width="0dp"
                        android:layout_height="46dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:text="SCAN QR"
                        android:fontFamily="monospace"
                        android:backgroundTint="#1A1A33"
                        android:textColor="#888899"
                        style="@style/Widget.MaterialComponents.Button"/>
                </LinearLayout>
                <Button
                    android:id="@+id/btnPushToChild"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginTop="8dp"
                    android:text="📡  PUSH URL TO CHILD"
                    android:fontFamily="monospace"
                    android:backgroundTint="#1A0030"
                    android:textColor="#AA00FF"
                    style="@style/Widget.MaterialComponents.Button"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ═══ QR CODE ═══ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#0D0D21"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="10dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:gravity="center">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="QR CODE"
                    android:textColor="#333355"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="12dp"/>
                <ImageView
                    android:id="@+id/ivQrCode"
                    android:layout_width="200dp"
                    android:layout_height="200dp"
                    android:background="#111122"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Child app scans this to auto-connect"
                    android:textColor="#333355"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:layout_marginTop="8dp"/>
                <TextView
                    android:id="@+id/tvConnectionInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#00C853"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:layout_marginTop="8dp"
                    android:gravity="center"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ═══ OTA AUTO-UPDATE ═══ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#0D0D21"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="10dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <View
                        android:layout_width="4dp"
                        android:layout_height="18dp"
                        android:background="#00C853"
                        android:layout_marginEnd="8dp"/>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="OTA AUTO-UPDATE"
                        android:textColor="#00C853"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.1"/>
                    <TextView
                        android:id="@+id/tvOtaVersion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="v?"
                        android:textColor="#333355"
                        android:textSize="11sp"
                        android:fontFamily="monospace"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GitHub Repo (ChildMonitor)"
                    android:textColor="#555566"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="4dp"/>
                <EditText
                    android:id="@+id/etGithubRepo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="owner/ChildMonitor"
                    android:inputType="text"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#333355"
                    android:background="#0A0A1A"
                    android:padding="12dp"
                    android:fontFamily="monospace"
                    android:textSize="13sp"
                    android:layout_marginBottom="6dp"/>

                <!-- BUG FIX: Private repo ke liye GitHub token zaroori tha lekin koi UI nahi tha.
                     Token "github_prefs/github_token" se read hota tha lekin save karne ka koi
                     tariqa nahi tha — OTA hamesha 404 deta tha private repos pe. -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GitHub Token (private repo ke liye, optional)"
                    android:textColor="#555566"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="4dp"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">
                    <EditText
                        android:id="@+id/etGithubToken"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="ghp_xxxxxxxxxxxx"
                        android:inputType="textPassword"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#333355"
                        android:background="#0A0A1A"
                        android:padding="12dp"
                        android:fontFamily="monospace"
                        android:textSize="13sp"
                        android:layout_marginEnd="6dp"/>
                    <Button
                        android:id="@+id/btnSaveGithubToken"
                        android:layout_width="wrap_content"
                        android:layout_height="46dp"
                        android:text="SAVE"
                        android:fontFamily="monospace"
                        android:backgroundTint="#1A1A33"
                        android:textColor="#888899"
                        style="@style/Widget.MaterialComponents.Button"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <Button
                        android:id="@+id/btnCheckUpdate"
                        android:layout_width="0dp"
                        android:layout_height="46dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:text="🔍 CHECK"
                        android:fontFamily="monospace"
                        android:backgroundTint="#001A33"
                        android:textColor="#00E5FF"
                        style="@style/Widget.MaterialComponents.Button"/>
                    <Button
                        android:id="@+id/btnPushUpdate"
                        android:layout_width="0dp"
                        android:layout_height="46dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:text="🚀 PUSH APK"
                        android:fontFamily="monospace"
                        android:backgroundTint="#002200"
                        android:textColor="#00C853"
                        android:enabled="false"
                        style="@style/Widget.MaterialComponents.Button"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvUpdateStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Connect GitHub repo above → check for latest APK release → push update directly to child device via relay"
                    android:textColor="#2A2A44"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:lineSpacingExtra="3dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
