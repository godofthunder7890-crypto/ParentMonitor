<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#050508"
    android:padding="12dp">

    <TextView android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🎮  Remote Control"
        android:textColor="#00D4FF" android:textSize="16sp" android:textStyle="bold"
        android:layout_marginBottom="10dp"/>

    <!-- TOUCHPAD -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="12dp"
        app:cardBackgroundColor="#0D0D1A"
        app:cardCornerRadius="16dp">

        <LinearLayout android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="10dp" android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Touchpad  (drag = swipe  •  tap = click)"
                    android:textColor="#444" android:textSize="11sp"/>
                <TextView android:id="@+id/tvTouchCoords"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="x:0 y:0"
                    android:textColor="#333" android:textSize="11sp"/>
            </LinearLayout>

            <View
                android:id="@+id/touchPad"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_margin="8dp"
                android:background="#080816"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- NAV BAR BUTTONS -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        app:cardBackgroundColor="#0D0D1A"
        app:cardCornerRadius="12dp">

        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="10dp">

            <Button android:id="@+id/btnNavBack"
                android:layout_width="0dp" android:layout_height="44dp"
                android:layout_weight="1" android:layout_marginEnd="6dp"
                android:text="◀  Back" android:textSize="13sp"
                android:backgroundTint="#1A1A2E" android:textColor="#CCC"/>

            <Button android:id="@+id/btnNavHome"
                android:layout_width="0dp" android:layout_height="44dp"
                android:layout_weight="1" android:layout_marginEnd="6dp"
                android:text="⬤  Home" android:textSize="13sp"
                android:backgroundTint="#1A1A2E" android:textColor="#CCC"/>

            <Button android:id="@+id/btnNavRecents"
                android:layout_width="0dp" android:layout_height="44dp"
                android:layout_weight="1"
                android:text="▣  Recents" android:textSize="13sp"
                android:backgroundTint="#1A1A2E" android:textColor="#CCC"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ACTION BUTTONS -->
    <LinearLayout android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button android:id="@+id/btnCtrlLock"
            android:layout_width="0dp" android:layout_height="44dp"
            android:layout_weight="1" android:layout_marginEnd="6dp"
            android:text="🔒 Lock" android:textSize="12sp"
            android:backgroundTint="#FF4444" android:textColor="#FFF"/>

        <Button android:id="@+id/btnCtrlLocation"
            android:layout_width="0dp" android:layout_height="44dp"
            android:layout_weight="1" android:layout_marginEnd="6dp"
            android:text="📍 Track" android:textSize="12sp"
            android:backgroundTint="#0D47A1" android:textColor="#FFF"/>

        <Button android:id="@+id/btnCtrlBattery"
            android:layout_width="0dp" android:layout_height="44dp"
            android:layout_weight="1"
            android:text="🔋 Batt" android:textSize="12sp"
            android:backgroundTint="#1B5E20" android:textColor="#FFF"/>

    </LinearLayout>

</LinearLayout>
