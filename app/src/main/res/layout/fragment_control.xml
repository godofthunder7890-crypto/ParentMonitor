<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#060612">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#0A0A1E"
        android:paddingHorizontal="14dp"
        android:gravity="center_vertical">

        <TextView android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="REMOTE CONTROL"
            android:textColor="#00E5FF"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.1"/>

        <TextView android:id="@+id/tvTouchCoords"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="x:0  y:0"
            android:textColor="#333"
            android:textSize="12sp"
            android:fontFamily="monospace"/>
    </LinearLayout>

    <!-- TOUCHPAD -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_margin="12dp"
        app:cardBackgroundColor="#0A0A1E"
        app:cardCornerRadius="18dp"
        app:cardElevation="4dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <View
                android:id="@+id/touchPad"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#0A0A1E"/>

            <!-- Center crosshair hint -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="Touch here to control\n\nDrag = swipe\nTap = click"
                android:textColor="#1A1A3E"
                android:textSize="14sp"
                android:gravity="center"
                android:lineSpacingMultiplier="1.8"/>

        </FrameLayout>
    </androidx.cardview.widget.CardView>

    <!-- NAV BUTTONS -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingBottom="8dp">

        <Button android:id="@+id/btnNavBack"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:layout_marginEnd="6dp"
            android:text="◀ Back"
            android:textSize="13sp" android:textColor="#CCC"
            android:backgroundTint="#1A1A2E"
            android:stateListAnimator="@null"/>

        <Button android:id="@+id/btnNavHome"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:layout_marginEnd="6dp"
            android:text="⬤ Home"
            android:textSize="13sp" android:textColor="#CCC"
            android:backgroundTint="#1A1A2E"
            android:stateListAnimator="@null"/>

        <Button android:id="@+id/btnNavRecents"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="▣ Recent"
            android:textSize="13sp" android:textColor="#CCC"
            android:backgroundTint="#1A1A2E"
            android:stateListAnimator="@null"/>

    </LinearLayout>

    <!-- ACTION BUTTONS -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingBottom="10dp">

        <Button android:id="@+id/btnCtrlLock"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:layout_marginEnd="6dp"
            android:text="🔒 Lock"
            android:textSize="12sp" android:textColor="#FFF"
            android:backgroundTint="#B71C1C"
            android:stateListAnimator="@null"/>

        <Button android:id="@+id/btnCtrlLocation"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:layout_marginEnd="6dp"
            android:text="📍 GPS"
            android:textSize="12sp" android:textColor="#FFF"
            android:backgroundTint="#0D47A1"
            android:stateListAnimator="@null"/>

        <Button android:id="@+id/btnCtrlBattery"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="🔋 Batt"
            android:textSize="12sp" android:textColor="#FFF"
            android:backgroundTint="#1B5E20"
            android:stateListAnimator="@null"/>

    </LinearLayout>

</LinearLayout>
