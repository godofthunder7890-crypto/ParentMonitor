<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#070714"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- STATUS CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="130dp"
            android:background="#0E0E22"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="18dp"
            android:layout_marginBottom="10dp">

            <!-- Pulse ring + dot -->
            <FrameLayout
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginEnd="16dp">
                <View
                    android:id="@+id/statusRing"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/circle_red"
                    android:alpha="0.2"
                    android:layout_gravity="center"/>
                <View
                    android:id="@+id/bigStatusDot"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/circle_red"
                    android:layout_gravity="center"/>
            </FrameLayout>

            <!-- Status text -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tvChildStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CHILD OFFLINE"
                    android:textColor="#F44336"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"/>
                <TextView
                    android:id="@+id/tvLastSeen"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Never connected"
                    android:textColor="#4D4D70"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp"/>
                <TextView
                    android:id="@+id/tvDashCurrentApp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="#00E5FF"
                    android:textSize="12sp"
                    android:layout_marginTop="6dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- STATS ROW -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <!-- Battery -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="#0E0E22"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="6dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BATTERY"
                    android:textColor="#4D4D70"
                    android:textSize="9sp"
                    android:letterSpacing="0.1"/>
                <TextView
                    android:id="@+id/tvDashBattery"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="#00E676"
                    android:textSize="22sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Ping -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="#0E0E22"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="3dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PING"
                    android:textColor="#4D4D70"
                    android:textSize="9sp"
                    android:letterSpacing="0.1"/>
                <TextView
                    android:id="@+id/tvDashPing"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="#00E5FF"
                    android:textSize="22sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Location -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="2"
                android:background="#0E0E22"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginStart="6dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LOCATION"
                    android:textColor="#4D4D70"
                    android:textSize="9sp"
                    android:letterSpacing="0.1"/>
                <TextView
                    android:id="@+id/tvDashLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="#69F0AE"
                    android:textSize="11sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

        <!-- QUICK ACTIONS LABEL -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="QUICK ACTIONS"
            android:textColor="#4D4D70"
            android:textSize="10sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="8dp"/>

        <!-- QUICK ACTIONS GRID ROW 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btnDashLock"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="LOCK"
                android:textSize="11sp"
                android:textColor="#000"
                android:fontFamily="sans-serif-bold"
                android:backgroundTint="#FF1744"
                android:stateListAnimator="@null"
                android:layout_marginEnd="6dp"/>

            <Button
                android:id="@+id/btnDashCamera"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="PHOTO"
                android:textSize="11sp"
                android:textColor="#000"
                android:fontFamily="sans-serif-bold"
                android:backgroundTint="#AA00FF"
                android:stateListAnimator="@null"
                android:layout_marginEnd="6dp"/>

            <Button
                android:id="@+id/btnDashLocation"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="LOCATE"
                android:textSize="11sp"
                android:textColor="#000"
                android:fontFamily="sans-serif-bold"
                android:backgroundTint="#00E5FF"
                android:stateListAnimator="@null"/>
        </LinearLayout>

        <!-- QUICK ACTIONS GRID ROW 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btnDashBattery"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="BATTERY"
                android:textSize="11sp"
                android:textColor="#000"
                android:fontFamily="sans-serif-bold"
                android:backgroundTint="#FFD600"
                android:stateListAnimator="@null"
                android:layout_marginEnd="6dp"/>

            <Button
                android:id="@+id/btnDashCurrentApp"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="CURR APP"
                android:textSize="11sp"
                android:textColor="#000"
                android:fontFamily="sans-serif-bold"
                android:backgroundTint="#00C853"
                android:stateListAnimator="@null"
                android:layout_marginEnd="6dp"/>

            <Button
                android:id="@+id/btnDashGrantPerms"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="PERMS"
                android:textSize="11sp"
                android:textColor="#000"
                android:fontFamily="sans-serif-bold"
                android:backgroundTint="#FF6D00"
                android:stateListAnimator="@null"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
