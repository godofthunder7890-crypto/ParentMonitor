<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#080B14">

    <!-- Header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
        android:background="#111827" android:paddingHorizontal="14dp" android:gravity="center_vertical">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="🔍 SOCIAL MEDIA DETECTION"
            android:textColor="#38BDF8" android:textSize="13sp"
            android:fontFamily="sans-serif-medium" android:letterSpacing="0.1"/>
        <TextView android:id="@+id/tvSocialStatus"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="OFF" android:textColor="#666" android:textSize="11sp"/>
    </LinearLayout>

    <!-- Config Card -->
    <androidx.cardview.widget.CardView android:layout_width="match_parent"
        android:layout_height="wrap_content" android:layout_margin="12dp"
        app:cardBackgroundColor="#0D1117" app:cardCornerRadius="14dp" app:cardElevation="3dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="14dp">

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Detects: Violence • Drugs • Adult Content • Bullying • Grooming • Self-Harm"
                android:textColor="#999" android:textSize="12sp" android:layout_marginBottom="10dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <Switch android:id="@+id/swSocialEnabled"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Enable Detection"
                    android:textColor="#CCC"/>
                <Button android:id="@+id/btnSocialApply"
                    android:layout_width="wrap_content" android:layout_height="38dp"
                    android:layout_marginEnd="8dp"
                    android:text="Apply" android:textSize="12sp" android:textColor="#FFF"
                    android:backgroundTint="#1565C0" android:stateListAnimator="@null"/>
                <Button android:id="@+id/btnSocialClear"
                    android:layout_width="wrap_content" android:layout_height="38dp"
                    android:text="Clear" android:textSize="12sp" android:textColor="#FFF"
                    android:backgroundTint="#37474F" android:stateListAnimator="@null"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Alerts List -->
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="ALERTS (newest first)" android:textColor="#555"
        android:textSize="10sp" android:letterSpacing="0.1"
        android:paddingHorizontal="14dp" android:paddingBottom="6dp"/>

    <ListView android:id="@+id/lvSocialAlerts"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:divider="#111827" android:dividerHeight="1dp"/>

</LinearLayout>
